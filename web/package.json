{
  "name": "escape-velocity-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "wasm:build": "wasm-pack build ../crates/fractal-wasm --target web --out-dir ../../web/wasm --release",
    "dev": "pnpm wasm:build && vite",
    "build": "pnpm wasm:build && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm wasm:build && tsc --noEmit",
    "lint": "biome ci",
    "fmt": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0"
  }
}
